{
  "name": "@gmisoftware/przelewy24-payments-medusa",
  "version": "0.0.6",
  "description": "Przelewy24 (P24) payment integration plugin for Medusa e-commerce with BLIK, cards, and general P24 support.",
  "author": "GMI",
  "license": "MIT",
  "repository": "https://github.com/gmi-software/przelewy24-medusa",
  "files": [
    ".medusa/server"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    },
    "./*": "./.medusa/server/src/*.js"
  },
  "keywords": [
    "medusa",
    "plugin",
    "medusa-plugin-payment",
    "medusa-plugin",
    "medusa-plugin-integration",
    "medusa-v2",
    "przelewy24",
    "p24",
    "blik",
    "payment",
    "poland"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "prepublishOnly": "medusa plugin:build",
    "test": "vitest run"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "2.13.2",
    "@medusajs/cli": "2.13.2",
    "@medusajs/framework": "2.13.2",
    "@medusajs/medusa": "2.13.2",
    "@medusajs/test-utils": "2.13.2",
    "@medusajs/ui": "4.0.25",
    "@medusajs/icons": "2.13.2",
    "@swc/core": "^1.7.28",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.2.11",
    "vitest": "^4.0.18",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "2.13.2",
    "@medusajs/cli": "2.13.2",
    "@medusajs/framework": "2.13.2",
    "@medusajs/test-utils": "2.13.2",
    "@medusajs/medusa": "2.13.2",
    "@medusajs/ui": "4.0.25",
    "@medusajs/icons": "2.13.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
